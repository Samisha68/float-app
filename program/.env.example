# Float AI Agent — Environment Variables
# Copy this to .env and fill in your values

# Required for AI agent (ai-agent.js)
OPENAI_API_KEY=sk-...your-key-here...

# Optional: override devnet RPC (use helius/quicknode for better rate limits)
# RPC=https://api.devnet.solana.com

# Keypair paths (defaults to ./agent.json and ./admin.json)
# AGENT_KEYPAIR=./agent.json
# ADMIN_KEYPAIR=./admin.json
